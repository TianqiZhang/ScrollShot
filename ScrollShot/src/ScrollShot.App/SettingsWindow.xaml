<Window x:Class="ScrollShot.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScrollShot Settings"
        Height="640"
        Width="720"
        MinHeight="600"
        MinWidth="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                       Text="Settings" />
            <TextBlock Margin="0,8,0,6"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Text="Choose where images are saved and how you start a capture" />
            <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}"
                       Text="These are secondary options, so they live in a separate window instead of the main capture screen." />
        </StackPanel>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                               Text="Where to save images" />
                    <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                               Text="Save images to" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SaveFolderTextBox"
                                 Grid.Column="0"
                                 Margin="0,0,12,8" />
                        <Button Grid.Column="1"
                                Margin="0,0,0,8"
                                Content="Browse"
                                Click="OnBrowseSaveFolderClick" />
                    </Grid>

                    <TextBlock Margin="0,0,0,16"
                               Style="{StaticResource SectionSubtitleTextBlockStyle}"
                               Text="Each image is saved with the capture time in its file name." />

                    <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                               Text="Keyboard shortcut" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="Shortcut keys" />
                            <ComboBox x:Name="HotkeyModifiersComboBox"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="OnHotkeySelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                       Text="Main key" />
                            <ComboBox x:Name="HotkeyKeyComboBox"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="OnHotkeySelectionChanged" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,8,0,0"
                            Background="{DynamicResource CardMutedBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       Text="Current shortcut" />
                            <TextBlock x:Name="HotkeyHelpTextBlock"
                                       Margin="0,6,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Ctrl+Shift+S" />
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,8,0,16"
                               Style="{StaticResource SectionSubtitleTextBlockStyle}"
                               Text="This shortcut keeps working while ScrollShot is running in the tray." />

                    <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                               Text="Extra options" />
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="Open ScrollShot when I sign in to Windows" />
                    <CheckBox x:Name="ScrollCaptureDebugDumpEnabledCheckBox"
                              Content="Save diagnostic files while capturing a scrolling page" />

                    <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                               Text="Diagnostic files folder" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DebugDumpFolderTextBox"
                                 Grid.Column="0"
                                 Margin="0,0,12,8" />
                        <Button Grid.Column="1"
                                Margin="0,0,0,8"
                                Content="Browse"
                                Click="OnBrowseDebugDumpFolderClick" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}"
                               Text="Turn this on only if something is not working as expected. It saves extra capture data to disk." />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="4"
                   LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                       TextWrapping="Wrap"
                       Text="Ready." />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Width="90"
                        Margin="0,0,12,0"
                        Content="Close"
                        IsCancel="True" />
                <Button Width="130"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Save Changes"
                        Click="OnSaveSettingsClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
