<Window x:Class="ScrollShot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScrollShot"
        Height="400"
        Width="860"
        MinHeight="340"
        MinWidth="760"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Settings"
                      Click="OnOpenSettingsClick" />
        </Menu>

        <Grid Grid.Row="1"
              Margin="24">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Text="ScrollShot" />
                        <TextBlock Margin="0,10,0,8"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="Capture a scrolling page in a few seconds." />
                        <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                   Text="Use the Settings menu if you want to change where images are saved or choose a different shortcut." />
                        <Border Margin="0,18,0,0"
                                Background="{DynamicResource CardMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Text="Current shortcut" />
                                <TextBlock x:Name="HotkeySummaryTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Ctrl+Shift+S" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                           Text="ScrollShot stays in the tray after you close this window, so this shortcut keeps working." />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <Button Width="170"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Start Capture"
                                Click="OnNewCaptureClick" />
                        <Button Width="170"
                                Content="Open Saved Images"
                                Click="OnOpenSaveFolderClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
