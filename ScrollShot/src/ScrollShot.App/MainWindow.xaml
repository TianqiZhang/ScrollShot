<Window x:Class="ScrollShot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScrollShot"
        Height="720"
        Width="920"
        MinHeight="640"
        MinWidth="820"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Text="ScrollShot" />
                        <TextBlock Margin="0,10,0,8"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="Capture long content without wrestling the UI." />
                        <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                   Text="Start a new capture, keep a readable shortcut, and tune advanced options only when you need them." />
                        <Border Margin="0,18,0,0"
                                Background="{DynamicResource CardMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Text="Current shortcut" />
                                <TextBlock x:Name="HotkeySummaryTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Ctrl+Shift+S" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                           Text="Close the window anytime. ScrollShot stays in the tray and the hotkey continues to work." />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <Button Width="180"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Start New Capture"
                                Click="OnNewCaptureClick" />
                        <Button Width="180"
                                Content="Open Save Folder"
                                Click="OnOpenSaveFolderClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <Expander IsExpanded="False">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}"
                                       Text="Settings" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                       Text="Save location, shortcut, and advanced options." />
                        </StackPanel>
                    </Expander.Header>

                    <StackPanel Margin="0,18,0,0">
                        <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="Save folder" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SaveFolderTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,12,8" />
                            <Button Grid.Column="1"
                                    Margin="0,0,0,8"
                                    Content="Browse"
                                    Click="OnBrowseSaveFolderClick" />
                        </Grid>

                        <TextBlock Margin="0,0,0,16"
                                   Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                   Text="Files are named with a capture timestamp. A synced screenshots folder works well if you share captures often." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                           Text="Modifiers" />
                                <ComboBox x:Name="HotkeyModifiersComboBox"
                                          DisplayMemberPath="Label"
                                          SelectionChanged="OnHotkeySelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                           Text="Key" />
                                <ComboBox x:Name="HotkeyKeyComboBox"
                                          DisplayMemberPath="Label"
                                          SelectionChanged="OnHotkeySelectionChanged" />
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,8,0,0"
                                Background="{DynamicResource CardMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Text="Registered hotkey" />
                                <TextBlock x:Name="HotkeyHelpTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Ctrl+Shift+S" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,8,0,16"
                                   Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                   Text="The shortcut keeps working while ScrollShot is hidden in the tray." />

                        <CheckBox x:Name="StartWithWindowsCheckBox"
                                  Content="Start ScrollShot automatically when Windows starts" />
                        <CheckBox x:Name="ScrollCaptureDebugDumpEnabledCheckBox"
                                  Content="Save raw scroll-capture debug dumps for replay and stitching analysis" />

                        <TextBlock Style="{StaticResource FieldLabelTextBlockStyle}"
                                   Text="Debug dump folder" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DebugDumpFolderTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,12,8" />
                            <Button Grid.Column="1"
                                    Margin="0,0,0,8"
                                    Content="Browse"
                                    Click="OnBrowseDebugDumpFolderClick" />
                        </Grid>

                        <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}"
                                   Text="Enable this only while diagnosing stitching issues. It stores frame sequences and reports on disk." />

                        <Button Width="150"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Save Settings"
                                Click="OnSaveSettingsClick" />

                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,12,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Text="Ready." />
                    </StackPanel>
                </Expander>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
