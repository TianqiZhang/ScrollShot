<UserControl x:Class="ScrollShot.Editor.Controls.ImageViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Border Background="{DynamicResource CardMutedBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <ScrollViewer x:Name="ScrollViewer"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto"
                       PreviewMouseWheel="OnPreviewMouseWheel"
                       MouseLeftButtonDown="OnMouseLeftButtonDown"
                       MouseLeftButtonUp="OnMouseLeftButtonUp"
                       MouseMove="OnMouseMove"
                       MouseRightButtonDown="OnMouseRightButtonDown"
                       MouseRightButtonUp="OnMouseRightButtonUp">
            <Grid HorizontalAlignment="Left"
                  VerticalAlignment="Top">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ScaleTransform"
                                    ScaleX="1"
                                    ScaleY="1" />
                </Grid.LayoutTransform>
                <Image x:Name="ViewportImage"
                       Stretch="None" />
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        ClipToBounds="True">
                    <!-- Dim overlay: 4 rectangles around crop -->
                    <Rectangle x:Name="DimTop" Fill="#66000000" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="DimBottom" Fill="#66000000" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="DimLeft" Fill="#66000000" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="DimRight" Fill="#66000000" Visibility="Collapsed" IsHitTestVisible="False" />

                    <!-- Crop border -->
                    <Rectangle x:Name="CropBorder"
                               Stroke="{DynamicResource AccentBrush}"
                               StrokeThickness="2"
                               Fill="Transparent"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />

                    <!-- 8 crop handles -->
                    <Rectangle x:Name="HandleTL" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleTC" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleTR" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleML" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleMR" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleBL" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleBC" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />
                    <Rectangle x:Name="HandleBR" Width="10" Height="10" Fill="{DynamicResource AccentBrush}" Visibility="Collapsed" IsHitTestVisible="False" />

                    <!-- Cut band preview during drag -->
                    <Rectangle x:Name="CutBandPreview"
                               Fill="#50DC3545"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
