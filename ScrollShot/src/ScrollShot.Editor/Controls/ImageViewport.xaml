<UserControl x:Class="ScrollShot.Editor.Controls.ImageViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Border Background="{DynamicResource CardMutedBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <ScrollViewer x:Name="ScrollViewer"
                       PreviewMouseWheel="OnPreviewMouseWheel"
                       MouseLeftButtonDown="OnMouseLeftButtonDown"
                       MouseLeftButtonUp="OnMouseLeftButtonUp"
                       MouseMove="OnMouseMove">
            <Grid>
                <Image x:Name="ViewportImage"
                       Stretch="None"
                       RenderTransformOrigin="0,0">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="ScaleTransform"
                                        ScaleX="1"
                                        ScaleY="1" />
                    </Image.RenderTransform>
                </Image>
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent">
                    <Rectangle x:Name="CropRectangle"
                               Stroke="{DynamicResource AccentBrush}"
                               StrokeThickness="2"
                               Fill="#2260A5FA"
                               Visibility="Collapsed" />
                </Canvas>
                <Border Margin="16"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#CC0B1220"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,6"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="ModeBadgeTextBlock"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"
                               Text="Move" />
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
