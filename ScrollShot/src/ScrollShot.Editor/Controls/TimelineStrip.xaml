<UserControl x:Class="ScrollShot.Editor.Controls.TimelineStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="200">
    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="ModeTextBlock"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="Trim ends" />
                <TextBlock x:Name="HintTextBlock"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap"
                           Text="Drag the top and bottom handles to shorten the capture." />
            </StackPanel>

            <Grid Grid.Row="2">
                <Image x:Name="ThumbnailImage"
                       Stretch="Fill" />
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="OnOverlayMouseLeftButtonDown"
                        MouseLeftButtonUp="OnOverlayMouseLeftButtonUp"
                        MouseMove="OnOverlayMouseMove" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
