<Window x:Class="ScrollShot.Overlay.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ScrollShot.Overlay.Controls"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        KeyDown="OnWindowKeyDown"
        PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
        PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
        PreviewMouseMove="OnPreviewMouseMove"
        PreviewMouseWheel="OnPreviewMouseWheel">
    <Canvas x:Name="RootCanvas"
            Background="Transparent">
        <Rectangle x:Name="TopShade" Fill="#88000000" />
        <Rectangle x:Name="LeftShade" Fill="#88000000" />
        <Rectangle x:Name="RightShade" Fill="#88000000" />
        <Rectangle x:Name="BottomShade" Fill="#88000000" />
        <Border x:Name="InstructionBorder"
                Width="420"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22,18"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           Text="Capture" />
                <TextBlock Margin="0,10,0,8"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="Select an area to capture" />
                <TextBlock x:Name="InstructionText"
                           FontSize="14"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap"
                           Text="1. Drag over the area you want.&#x0a;2. Release the mouse, then press Enter for a screenshot or use the mouse wheel to start scrolling capture. Hold Shift while scrolling for side-to-side capture.&#x0a;3. Press Esc at any time to cancel." />
            </StackPanel>
        </Border>
        <Border x:Name="SelectionBorder"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                CornerRadius="18"
                Background="#10060D1B"
                Visibility="Collapsed" />
        <controls:LivePreviewStrip x:Name="PreviewStrip"
                                    Visibility="Collapsed" />
    </Canvas>
</Window>
