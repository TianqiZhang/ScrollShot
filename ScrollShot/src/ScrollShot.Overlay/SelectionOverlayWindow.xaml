<Window x:Class="ScrollShot.Overlay.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ScrollShot.Overlay.Controls"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        KeyDown="OnWindowKeyDown"
        PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
        PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
        PreviewMouseMove="OnPreviewMouseMove"
        PreviewMouseWheel="OnPreviewMouseWheel">
    <Canvas x:Name="RootCanvas"
            Background="Transparent">
        <Rectangle x:Name="TopShade" Fill="#88000000" />
        <Rectangle x:Name="LeftShade" Fill="#88000000" />
        <Rectangle x:Name="RightShade" Fill="#88000000" />
        <Rectangle x:Name="BottomShade" Fill="#88000000" />
        <Border x:Name="InstructionBorder"
                Width="420"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22,18"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           Text="Capture" />
                <TextBlock Margin="0,10,0,8"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="Choose what you want to capture" />
                <TextBlock x:Name="InstructionText"
                           FontSize="14"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap"
                           Text="1. Drag over the area you want.&#x0a;2. Choose a capture mode.&#x0a;3. Press Esc at any time to cancel." />
            </StackPanel>
        </Border>
        <Border x:Name="ActionPanel"
                Width="340"
                Visibility="Collapsed"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <StackPanel>
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           Text="Selected area" />
                <TextBlock Margin="0,8,0,4"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="How would you like to capture it?" />
                <TextBlock x:Name="SelectionSummaryTextBlock"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="Selected area: 0 × 0" />
                <TextBlock Margin="0,6,0,14"
                           FontSize="13"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap"
                           Text="Tip: press Enter to take a screenshot, use the mouse wheel to start vertical capture, or Shift + wheel for side-to-side capture." />

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="Take Screenshot"
                        Click="OnInstantCaptureClick" />
                <Button Margin="0,10,0,0"
                        Content="Capture While Scrolling Down"
                        Click="OnVerticalScrollCaptureClick" />
                <Button Margin="0,10,0,0"
                        Content="Capture Side to Side"
                        Click="OnHorizontalScrollCaptureClick" />
                <Button Margin="0,10,0,0"
                        Content="Choose a Different Area"
                        Click="OnSelectAgainClick" />
            </StackPanel>
        </Border>
        <Border x:Name="SelectionBorder"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                CornerRadius="18"
                Background="#10060D1B"
                Visibility="Collapsed" />
        <controls:LivePreviewStrip x:Name="PreviewStrip"
                                    Visibility="Collapsed" />
    </Canvas>
</Window>
