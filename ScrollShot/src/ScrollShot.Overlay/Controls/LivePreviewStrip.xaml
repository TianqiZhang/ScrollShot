<UserControl x:Class="ScrollShot.Overlay.Controls.LivePreviewStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="280"
             d:DesignWidth="180">
    <Border CornerRadius="18"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           Text="Capture in progress" />
                <TextBlock x:Name="DirectionTextBlock"
                           Margin="0,8,0,4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           Text="Vertical capture" />
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="13"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap"
                           Text="Scroll the target window. Finish when the preview looks complete." />
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Background="{DynamicResource CardMutedBackgroundBrush}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           Width="200"
                           Height="260" />
                </ScrollViewer>
            </Border>

            <Button x:Name="DoneButton"
                    Grid.Row="4"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Finish Capture"
                    Click="OnDoneButtonClick" />
        </Grid>
    </Border>
</UserControl>
